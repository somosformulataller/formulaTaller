# ─────────────────────────────────────────────────────────────
# Supabase — get these from your project: Settings > API
# ─────────────────────────────────────────────────────────────

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to the browser). Used for admin actions
# like creating mechanic users and reading public tracking links.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployed app (used to build the client
# tracking links that are shared via WhatsApp).
# Locally: http://localhost:3000  — On Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
